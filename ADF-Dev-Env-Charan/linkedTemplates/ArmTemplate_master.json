{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "ADF-Dev-Env-Charan"
		},
		"LS_ADLS_Multifile_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_ADLS_Multifile'"
		},
		"LS_ADLS_outputMultifile_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_ADLS_outputMultifile'"
		},
		"LS_ADLS_parquet_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_ADLS_parquet'"
		},
		"LS_BLOB_excel_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_BLOB_excel'"
		},
		"LS_SQLServer_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_SQLServer'"
		},
		"LS_ADLS_Multifile_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevcharan.dfs.core.windows.net"
		},
		"LS_ADLS_outputMultifile_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevcharan.dfs.core.windows.net/"
		},
		"LS_ADLS_parquet_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevcharan.dfs.core.windows.net"
		},
		"LS_AzureSQL_Practice_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "charan-sql-server-dev.database.windows.net"
		},
		"LS_AzureSQL_Practice_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "db-practice-01"
		},
		"LS_AzureSQL_Practice_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "charanadmin"
		},
		"LS_KeyVault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://my-secure-vault-01.vault.azure.net/"
		},
		"LS_SQLServer_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "DESKTOP-DEVAR3N"
		},
		"LS_SQLServer_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "MYSqlDB"
		},
		"LS_SQLServer_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "Charan_ADF"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "ADF-Dev-Env-Charan_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_ADLS_Multifile_accountKey": {
						"value": "[parameters('LS_ADLS_Multifile_accountKey')]"
					},
					"LS_ADLS_outputMultifile_accountKey": {
						"value": "[parameters('LS_ADLS_outputMultifile_accountKey')]"
					},
					"LS_ADLS_parquet_accountKey": {
						"value": "[parameters('LS_ADLS_parquet_accountKey')]"
					},
					"LS_BLOB_excel_connectionString": {
						"value": "[parameters('LS_BLOB_excel_connectionString')]"
					},
					"LS_SQLServer_password": {
						"value": "[parameters('LS_SQLServer_password')]"
					},
					"LS_ADLS_Multifile_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_Multifile_properties_typeProperties_url')]"
					},
					"LS_ADLS_outputMultifile_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_outputMultifile_properties_typeProperties_url')]"
					},
					"LS_ADLS_parquet_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_parquet_properties_typeProperties_url')]"
					},
					"LS_KeyVault_properties_typeProperties_baseUrl": {
						"value": "[parameters('LS_KeyVault_properties_typeProperties_baseUrl')]"
					},
					"LS_AzureSQL_Practice_properties_typeProperties_server": {
						"value": "[parameters('LS_AzureSQL_Practice_properties_typeProperties_server')]"
					},
					"LS_AzureSQL_Practice_properties_typeProperties_database": {
						"value": "[parameters('LS_AzureSQL_Practice_properties_typeProperties_database')]"
					},
					"LS_AzureSQL_Practice_properties_typeProperties_userName": {
						"value": "[parameters('LS_AzureSQL_Practice_properties_typeProperties_userName')]"
					},
					"LS_SQLServer_properties_typeProperties_server": {
						"value": "[parameters('LS_SQLServer_properties_typeProperties_server')]"
					},
					"LS_SQLServer_properties_typeProperties_database": {
						"value": "[parameters('LS_SQLServer_properties_typeProperties_database')]"
					},
					"LS_SQLServer_properties_typeProperties_userName": {
						"value": "[parameters('LS_SQLServer_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "ADF-Dev-Env-Charan_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'ADF-Dev-Env-Charan_ArmTemplate_0')]"
			]
		}
	]
}